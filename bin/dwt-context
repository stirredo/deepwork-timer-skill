#!/bin/sh
# UserPromptSubmit hook: inject the current Deep Work Timer state into
# Claude's context on every prompt, so it can act on it (recommend a task,
# suggest a switch, flag an overdue session) without being asked.
#
# MULTI-SESSION ARBITER: when several Claude Code windows share the one
# server-side session, the user's prompts are the live signal of where
# their attention is. If this window's working directory is mapped to a
# task (`dwt map`), and the active segment points elsewhere, the hook
# switches the segment here (debounced + locked across windows). Sequential
# segments then split the pomodoro honestly across everything the user
# actually steered — totals stay wall-clock true.
#
# Reuses the statusline cache (60s background refresh, never blocks).
# Cache format: ends \t task_id \t label  (legacy: ends \t label)

CFG="$HOME/.deepworktimer"
CACHE="$CFG/statusline-cache"
TOKEN_FILE="$CFG/token"
ACT_FILE="$CFG/last-activity"
BIN="$(cd "$(dirname "$0")" && pwd)"
[ -f "$TOKEN_FILE" ] || exit 0

# How long without a prompt OR a dwt command before the session counts as
# abandoned rather than continuous. Past this, an expired pomodoro is NOT
# auto-logged (we cannot claim focus the user was not present for) — the
# hook asks instead. Default 15 min; override ACTIVITY_IDLE_SECONDS in config.
IDLE_SECONDS=900
[ -f "$CFG/config" ] && . "$CFG/config" 2>/dev/null
[ -n "${ACTIVITY_IDLE_SECONDS:-}" ] && IDLE_SECONDS="$ACTIVITY_IDLE_SECONDS"

# read the previous activity stamp, then mark this prompt as activity
now_boot=$(date +%s)
prev_activity=$(cat "$ACT_FILE" 2>/dev/null || echo 0)
case "$prev_activity" in (''|*[!0-9]*) prev_activity=0 ;; esac
echo "$now_boot" > "$ACT_FILE" 2>/dev/null || true
idle=$(( now_boot - prev_activity ))

# stdin carries the hook payload (JSON with "cwd"); never block on a TTY
HOOK_JSON=""
[ ! -t 0 ] && HOOK_JSON=$(cat 2>/dev/null || true)

# Resolve this window's task: an explicit session latch (dwt latch) wins
# over the cwd map (longest-prefix). Also breadcrumb the prompting
# session's id so `dwt latch` knows which window the user last spoke to.
mapped=$(HOOK_JSON="$HOOK_JSON" python3 -c '
import json, os, time
cfg = os.path.expanduser("~/.deepworktimer")
payload = {}
try:
    payload = json.loads(os.environ.get("HOOK_JSON") or "{}")
except Exception:
    pass
cwd = payload.get("cwd") or os.environ.get("PWD", "")
sid = payload.get("session_id") or ""

# breadcrumb: the most recent prompt came from this window
if sid:
    try:
        with open(os.path.join(cfg, "last-prompt"), "w") as f:
            f.write("{}\t{}\n".format(sid, cwd))
    except Exception:
        pass

# 1) session latch
latched = ""
try:
    with open(os.path.join(cfg, "latches")) as f:
        for line in f:
            parts = line.rstrip("\n").split("\t")
            if len(parts) >= 2 and parts[0] == sid:
                latched = parts[1]
except Exception:
    pass

# 2) cwd map (longest prefix)
best = ("", "")
try:
    with open(os.path.join(cfg, "taskmap")) as f:
        for line in f:
            parts = line.rstrip("\n").split("\t", 1)
            if len(parts) != 2:
                continue
            tid, path = parts
            if (cwd == path or cwd.startswith(path + "/")) and len(path) > len(best[1]):
                best = (tid, path)
except Exception:
    pass

print(latched or best[0])
' 2>/dev/null)

# trigger the same refresh logic the statusline uses
"$BIN/dwt-statusline" >/dev/null 2>&1

[ -f "$CACHE" ] || exit 0
state=$(cat "$CACHE" 2>/dev/null)

# Concrete proposal, not a bare abandon/start: resume an existing task or open
# a new one under an existing or new project.
PROPOSE="if substantive work is underway, propose tracking it — resume an existing task (\`dwt tasks\`) or open a new one (\`<desc> #skill @estimate\`) under an existing or new project (\`dwt projects\`); confirm the one-liner, then \`dwt start\`."

if [ "$state" = "none" ] || [ -z "$state" ]; then
    if [ -n "$mapped" ]; then
        echo "[dwt] no active session — this window's workdir maps to task $mapped; if substantive work is underway propose \`dwt start $mapped\` (see deepwork-timer skill)"
    else
        echo "[dwt] no active session — $PROPOSE"
    fi
    exit 0
fi

ends=${state%%	*}
rest=${state#*	}
tid=${rest%%	*}
rest2=${rest#*	}
src_dev=${rest2%%	*}
label=${rest2#*	}
if [ "$label" = "$rest2" ]; then src_dev=""; label=$rest2; fi  # legacy cache
case "$tid" in (*[!0-9]*) tid="" ;; esac
[ -n "$ends" ] && [ "$ends" != "$state" ] || exit 0
now=$(date +%s)
left=$(( ends - now ))
# stable machine identity — must match dwt's machine_label() exactly
this_dev=$(scutil --get LocalHostName 2>/dev/null || hostname -s 2>/dev/null || hostname 2>/dev/null || echo dwt)

# ---- autonomous work machine: SEIZE a foreign-owned session ----------------
# DWT_AUTONOMOUS=1 opts THIS device out of the foreign-session protection: it
# owns its focus, so a session running on another device (phone at the gym,
# other laptop) is taken over here rather than deferred to. If this window
# maps to a task, hard-start it (dwt start = clean takeover, new session owned
# by this device; the other device logs its own prior time). Debounced via the
# shared arbiter lock — at most one seize/switch per 60s, so we do not re-seize
# every prompt in the window before the cache refreshes to this device.
if [ "${DWT_AUTONOMOUS:-}" = "1" ] && [ -n "$src_dev" ] && [ "$src_dev" != "$this_dev" ]; then
    if [ -n "$mapped" ]; then
        seized=0
        if mkdir "$CFG/arbiter.lock" 2>/dev/null; then
            last=$(cat "$CFG/arbiter-last" 2>/dev/null || echo 0)
            case "$last" in (*[!0-9]*|'') last=0 ;; esac
            if [ $(( now - last )) -ge 60 ]; then
                echo "$now" > "$CFG/arbiter-last"
                ( "$BIN/dwt" start "$mapped" >/dev/null 2>&1 & ) 2>/dev/null
                seized=1
            fi
            rmdir "$CFG/arbiter.lock" 2>/dev/null
        fi
        if [ "$seized" = 1 ]; then
            echo "[dwt] (autonomous) took the account session onto this window's task $mapped — fresh pomodoro started here; '$src_dev' logs its own prior time."
        else
            echo "[dwt] (autonomous) seizing onto task $mapped shortly (debounced); it was running from '$src_dev'."
        fi
        exit 0
    fi
    # unmapped: cannot seize to a specific task — do NOT surface the foreign
    # session; treat this machine as free and let the next task be proposed.
    echo "[dwt] no active session on this machine (one runs on '$src_dev' — not surfaced; autonomous machine). $PROPOSE"
    exit 0
fi

if [ "$left" -le 0 ]; then
    over=$(( -left ))
    # Continuous logging: the user is prompting a mapped/latched window, so
    # work demonstrably continues — log the finished pomodoro and roll
    # straight into the next one. No ceremony, no break enforcement (breaks
    # are a client-side ritual; machine-work days don't need the chunk
    # boundary to be visible). dwt log refuses foreign-device sessions, so
    # a phone-owned session falls through to the advisory line.
    if [ -n "$mapped" ] && [ "$idle" -le "$IDLE_SECONDS" ] && [ "$prev_activity" -gt 0 ] && mkdir "$CFG/arbiter.lock" 2>/dev/null; then
        if "$BIN/dwt" log >/dev/null 2>&1; then
            ( "$BIN/dwt" start "$mapped" >/dev/null 2>&1 & ) 2>/dev/null
            rmdir "$CFG/arbiter.lock" 2>/dev/null
            echo "[dwt] pomodoro on '$label' finished while you worked — auto-logged it and started a fresh session on task $mapped (continuous logging; tell Claude to \`dwt abandon\` when wrapping up)"
            exit 0
        fi
        rmdir "$CFG/arbiter.lock" 2>/dev/null
    fi
    # idle too long (or first prompt after a break): do NOT auto-credit a full
    # pomodoro the user may not have worked — surface the gap and let them decide
    if [ "$idle" -gt "$IDLE_SECONDS" ]; then
        echo "[dwt] session OVERDUE by $(( over / 60 ))m on '$label', and no activity for $(( idle / 60 ))m — NOT auto-logged (you were likely away). Ask the user, then \`dwt log\` (credit it) or \`dwt abandon\` (discard); \`dwt start\` to resume tracking."
        exit 0
    fi
    echo "[dwt] session OVERDUE by $(( over / 60 ))m on '$label' — propose \`dwt log\` to record it; then $PROPOSE"
    exit 0
fi

# ----- arbiter: steer the active segment toward this window's task -------
# Sessions owned by another device (phone at the gym) are PROPOSED, never
# auto-switched — one remote prompt must not hijack a workout's tracking.
arbiter_note=""
# (this_dev computed above.) Non-autonomous machines still defer to a
# foreign-owned session here — protection is the default; DWT_AUTONOMOUS
# opted out earlier.
if [ -n "$mapped" ] && [ -n "$tid" ] && [ "$mapped" != "$tid" ] && [ -n "$src_dev" ] && [ "$src_dev" != "$this_dev" ]; then
    echo "[dwt] active session: '$label' — $(( left / 60 )):$(printf '%02d' $(( left % 60 ))) left, running from '$src_dev' (another device). This window maps to task $mapped: if the user is back working HERE, propose \`dwt switch $mapped\`; if they are mid-workout/away, leave the session alone."
    exit 0
fi
if [ -n "$mapped" ] && [ -n "$tid" ] && [ "$mapped" != "$tid" ]; then
    # one switch at a time across all windows, at most one per 60s
    if mkdir "$CFG/arbiter.lock" 2>/dev/null; then
        last=$(cat "$CFG/arbiter-last" 2>/dev/null || echo 0)
        case "$last" in (*[!0-9]*|'') last=0 ;; esac
        if [ $(( now - last )) -ge 60 ]; then
            echo "$now" > "$CFG/arbiter-last"
            ( "$BIN/dwt" switch "$mapped" >/dev/null 2>&1 & ) 2>/dev/null
            arbiter_note=" Arbiter: switching the segment to task $mapped (this window's mapped task) — the pomodoro splits honestly across windows."
        else
            arbiter_note=" Arbiter: segment is on task $tid, this window maps to $mapped — switch debounced ($(( 60 - (now - last) ))s)."
        fi
        rmdir "$CFG/arbiter.lock" 2>/dev/null
    fi
fi

if [ -z "$arbiter_note" ]; then
    arbiter_note=" If the conversation's focus no longer matches, suggest \`dwt switch\`."
fi
echo "[dwt] active session: '$label' — $(( left / 60 )):$(printf '%02d' $(( left % 60 ))) left.$arbiter_note"
