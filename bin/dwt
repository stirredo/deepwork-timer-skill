#!/usr/bin/env bash
#
# dwt — Deep Work Timer CLI (https://deepworktimer.com)
#
# Dependency-light: bash + curl + python3 (stdlib only).
#
# Config:   ~/.deepworktimer/config   (KEY=VALUE; BASE_URL=... — defaults to https://deepworktimer.com)
# Token:    ~/.deepworktimer/token    (chmod 600)
# Session:  ~/.deepworktimer/session  (local-only "dwt start" state)
#
# Override the config dir with DWT_CONFIG_DIR (useful for testing).

set -euo pipefail

CONFIG_DIR="${DWT_CONFIG_DIR:-$HOME/.deepworktimer}"
CONFIG_FILE="$CONFIG_DIR/config"
TOKEN_FILE="$CONFIG_DIR/token"
SESSION_FILE="$CONFIG_DIR/session"

BASE_URL="https://deepworktimer.com"
DWT_AUTONOMOUS="${DWT_AUTONOMOUS:-0}"  # this machine seizes foreign sessions?

mkdir -p "$CONFIG_DIR"

# ---------------------------------------------------------------- config ----
if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
        case "$key" in
            BASE_URL) BASE_URL="$value" ;;
            DWT_AUTONOMOUS) DWT_AUTONOMOUS="$value" ;;
        esac
    done < "$CONFIG_FILE"
fi
BASE_URL="${BASE_URL%/}"

# --------------------------------------------------------------- helpers ----
die() { printf 'dwt: %s\n' "$*" >&2; exit 1; }

usage() {
    cat <<'EOF'
dwt — Deep Work Timer CLI (deepworktimer.com)

Usage:
  dwt login <email> [-p <password>]   Get an API token (password prompted if -p omitted)
  dwt token <raw-token>               Save a pasted API token directly
  dwt whoami                          Show the authenticated user
  dwt projects [--add <name>]         List projects (id, name) or create one
  dwt tasks [--project <id>]          List tasks (project tasks, or unassigned tasks)
  dwt add <description> [--project <id>] [--estimate <seconds>]
                                      Create a task
  dwt done <task_id>                  Mark a task completed
  dwt start <task_id> [--minutes <n>] Start a server session on a task
                                      (custom length 1..240 min; default is
                                      the account pomodoro length)
  dwt log [--task <id>] [--minutes <n>]
                                      Log a pomodoro. With no args, closes the
                                      session from "dwt start" using elapsed time.
  dwt map [<task_id>] [path]          Map a working directory to a task for the
                                      multi-session arbiter (no args: list maps;
                                      --remove [path] to delete; path defaults
                                      to the current directory)
  dwt latch [<task_id>]               Latch THIS Claude session to a task (outranks
                                      dwt map; --clear unbinds; no args lists)
  dwt repeat <task_id> <rule|--clear> Make a task recurring (every:7d, every:12h,
                                      weekly:mon,thu) — completion records the
                                      cycle and re-snoozes until the next wake
  dwt status                          Current session + today's total focus time
  dwt statusline-install              Append the live 🍅 segment to this
                                      machine's Claude Code statusline
  dwt autonomous [on|off|status]      Whether THIS machine seizes a session
                                      owned by another device (on) or defers
                                      to it (off, default)
  dwt hooks-install                   Inject live session state into Claude's
                                      context on every prompt (UserPromptSubmit)
  dwt stats                           Focus time summary (today/7d/30d/365d/all)

Config: ~/.deepworktimer/config (BASE_URL=https://deepworktimer.com by default)
EOF
}

# run an embedded python snippet; the last API response is exposed as $API_BODY
py() { API_BODY="${API_BODY:-}" python3 -c "$1" "${@:2}"; }

save_token() {
    umask 177
    printf '%s\n' "$1" > "$TOKEN_FILE"
    chmod 600 "$TOKEN_FILE"
}

require_token() {
    [ -s "$TOKEN_FILE" ] || die "no API token found. Run: dwt login <email>   (or paste one with: dwt token <raw-token>)"
}

# api METHOD PATH [JSON_BODY] -> sets API_STATUS, API_BODY
api() {
    local method="$1" path="$2" body="${3:-}"
    local args=(-sS -X "$method" "$BASE_URL/api$path" -H 'Accept: application/json' -w $'\n%{http_code}')
    if [ -s "$TOKEN_FILE" ]; then
        args+=(-H "Authorization: Bearer $(cat "$TOKEN_FILE")")
    fi
    if [ -n "$body" ]; then
        args+=(-H 'Content-Type: application/json' --data "$body")
    fi
    local raw
    if ! raw=$(curl "${args[@]}" 2>&1); then
        die "cannot reach $BASE_URL — $raw"
    fi
    API_STATUS="${raw##*$'\n'}"
    API_BODY="${raw%$'\n'*}"
    export API_BODY
}

# Session mutations must not leave the statusline/hook cache stale (it is
# otherwise only refreshed every 60s): drop it and repopulate in the
# background so the 🍅 segment and [dwt] context line update immediately.
refresh_statusline_cache() {
    rm -f "$CONFIG_DIR/statusline-cache"
    ( "$(cd "$(dirname "$0")" && pwd)/dwt-statusline" >/dev/null 2>&1 & ) 2>/dev/null || true
}

PY_MESSAGE='
import json, os, sys
try:
    d = json.loads(os.environ["API_BODY"])
except Exception:
    sys.exit(1)
parts = []
if isinstance(d, dict):
    if d.get("message"):
        parts.append(str(d["message"]))
    for field, msgs in (d.get("errors") or {}).items():
        if isinstance(msgs, list):
            parts.extend(str(m) for m in msgs)
seen, unique = set(), []
for p in parts:
    if p not in seen:
        seen.add(p)
        unique.append(p)
print(" ".join(unique) if unique else json.dumps(d))
'

extract_message() {
    py "$PY_MESSAGE" 2>/dev/null || printf '%s' "$API_BODY"
}

check_status() {
    case "$API_STATUS" in
        2*) return 0 ;;
        401) die "unauthorized (401) — your token is missing or expired. Run: dwt login <email>  (or: dwt token <raw-token>)" ;;
        403) die "forbidden (403): $(extract_message) — note: the API requires a verified email address." ;;
        422) die "validation error (422): $(extract_message)" ;;
        *)   die "HTTP $API_STATUS: $(extract_message)" ;;
    esac
}

now_utc() { date -u +%Y-%m-%dT%H:%M:%SZ; }

PY_ELAPSED='
import datetime, sys
start = datetime.datetime.strptime(sys.argv[1], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=datetime.timezone.utc)
print(int((datetime.datetime.now(datetime.timezone.utc) - start).total_seconds()))
'
elapsed_seconds() { py "$PY_ELAPSED" "$1"; }

PY_DURATION='
import sys
s = int(float(sys.argv[1]))
h, m, sec = s // 3600, (s % 3600) // 60, s % 60
print(f"{h}h {m}m" if h else (f"{m}m {sec}s" if m else f"{sec}s"))
'
pretty_duration() { py "$PY_DURATION" "$1"; }

read_session() {  # sets SESSION_TASK_ID, SESSION_STARTED_AT; returns 1 if none
    SESSION_TASK_ID="" SESSION_STARTED_AT=""
    [ -f "$SESSION_FILE" ] || return 1
    while IFS='=' read -r key value; do
        case "$key" in
            TASK_ID)    SESSION_TASK_ID="$value" ;;
            STARTED_AT) SESSION_STARTED_AT="$value" ;;
        esac
    done < "$SESSION_FILE"
    [ -n "$SESSION_TASK_ID" ] && [ -n "$SESSION_STARTED_AT" ]
}

# /api/stats/general wants statTimePeriod + start_date + end_date together
fetch_general_stats() {
    local dates start_date end_date
    dates=$(py '
import datetime
today = datetime.date.today()
print((today - datetime.timedelta(days=29)).isoformat(), today.isoformat())
')
    start_date="${dates%% *}"
    end_date="${dates##* }"
    api GET "/stats/general?statTimePeriod=daily&start_date=$start_date&end_date=$end_date"
    check_status
}

# -------------------------------------------------------------- commands ----
cmd_login() {
    local email="" password=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -p) password="${2:?-p needs a value}"; shift 2 ;;
            *)  [ -n "$email" ] && die "unexpected argument: $1"; email="$1"; shift ;;
        esac
    done
    [ -n "$email" ] || die "usage: dwt login <email> [-p <password>]"

    if [ -z "$password" ]; then
        if [ -t 0 ]; then
            printf 'Password for %s: ' "$email" >&2
            read -rs password
            printf '\n' >&2
        else
            read -r password || true
        fi
    fi
    [ -n "$password" ] || die "no password given (pipe it on stdin or use -p)"

    local body
    body=$(py 'import json, sys; print(json.dumps({"email": sys.argv[1], "password": sys.argv[2]}))' "$email" "$password")
    api POST "/login" "$body"
    [ "$API_STATUS" = "422" ] && die "login failed: $(extract_message)"
    check_status

    local token
    token=$(py 'import json, os; print(json.loads(os.environ["API_BODY"])["token"])') \
        || die "unexpected login response: $API_BODY"
    save_token "$token"
    echo "Logged in as $email. Token saved to $TOKEN_FILE"
}

cmd_token() {
    local raw="${1:-}"
    [ -n "$raw" ] || die "usage: dwt token <raw-token>"
    save_token "$raw"
    echo "Token saved to $TOKEN_FILE"
    api GET "/user"
    if [ "$API_STATUS" = "401" ]; then
        die "the token was saved but the API rejected it (401) — double-check it, then retry."
    fi
    check_status
    py '
import json, os
u = json.loads(os.environ["API_BODY"])
print("Authenticated as {} <{}>".format(u.get("name"), u.get("email")))
'
}

cmd_whoami() {
    require_token
    api GET "/user"
    check_status
    py '
import json, os
u = json.loads(os.environ["API_BODY"])
print("id:       {}".format(u.get("id")))
print("name:     {}".format(u.get("name")))
print("email:    {}".format(u.get("email")))
print("timezone: {}".format(u.get("timezone")))
s = u.get("user_settings") or {}
if s:
    print("pomodoro: {} min work / {} min short break".format(
        int(s.get("pomodoro_time") or 0) // 60, int(s.get("short_break_time") or 0) // 60))
'
}

cmd_projects() {
    require_token
    if [ "${1:-}" = "--add" ]; then
        local name="${2:?--add needs a project name}"
        api POST "/projects" "$(py 'import json,sys; print(json.dumps({"name": sys.argv[1]}))' "$name")"
        check_status
        py '
import json, os
d = json.loads(os.environ["API_BODY"])
p = (d.get("data") or {}).get("project") or d.get("project") or {}
print("Created project {}: {}".format(p.get("id", "?"), p.get("name", "")))
'
        return 0
    fi
    api GET "/projects"
    check_status
    py '
import json, os
projects = json.loads(os.environ["API_BODY"]).get("data") or []
if not projects:
    print("(no projects)")
else:
    print("{:>6}  NAME".format("ID"))
    for p in projects:
        print("{:>6}  {}".format(p["id"], p.get("name") or ""))
'
}

cmd_tasks() {
    require_token
    local project="" later=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --project) project="${2:?--project needs a value}"; shift 2 ;;
            --later)   later=1; shift ;;
            *) die "unexpected argument: $1" ;;
        esac
    done
    local path="/tasks" sep='?'
    [ -n "$project" ] && { path="/tasks?project_id=$project"; sep='&'; }
    [ "$later" = 1 ] && path="$path${sep}snoozed=1"
    api GET "$path"
    check_status
    py '
import json, os
tasks = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("tasks") or []
def walk(items, depth=0):
    for t in items:
        mark = "x" if t.get("completed") else " "
        wake = t.get("snoozed_until")
        wake = "  (wakes {})".format(wake[:16].replace("T", " ")) if wake else ""
        print("{:>6}  [{}]   {}{}{}".format(t["id"], mark, "  " * depth, t.get("description") or "", wake))
        walk(t.get("children") or [], depth + 1)
if not tasks:
    print("(no tasks)")
else:
    print("{:>6}  DONE  DESCRIPTION".format("ID"))
    walk(tasks)
'
}

cmd_add() {
    require_token
    local description="" project="" estimate=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --project)  project="${2:?--project needs a value}"; shift 2 ;;
            --estimate) estimate="${2:?--estimate needs a value}"; shift 2 ;;
            *)  [ -n "$description" ] && die "unexpected argument: $1 (quote the description)"; description="$1"; shift ;;
        esac
    done
    [ -n "$description" ] || die 'usage: dwt add "<description>" [--project <id>] [--estimate <seconds>]'

    # NOTE: the create endpoint takes task_description (NOT description)
    local body
    body=$(py '
import json, sys
desc, project = sys.argv[1], sys.argv[2]
payload = {"task_description": desc}
if project:
    payload["project_id"] = int(project)
print(json.dumps(payload))
' "$description" "$project")
    api POST "/tasks" "$body"
    check_status
    local task_id
    task_id=$(py '
import json, os
t = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("task") or {}
print(t.get("id"))
')

    # API quirk: POST /api/tasks never extracts #skill tags (only the update
    # path calls extractEstAndSkills), so re-PATCH the same description to
    # make the server attach the skills. Must come BEFORE the estimate PATCH:
    # description extraction resets estimated_time when no @2h marker exists.
    local skills_attached
    api PATCH "/tasks/$task_id" "$(py '
import json, sys
print(json.dumps({"description": sys.argv[1]}))
' "$description")"
    check_status
    skills_attached=$(py '
import json, os
t = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("task") or {}
print(", ".join(sorted(tag.get("name", "?") for tag in (t.get("tags") or []))))
')

    # API quirk: POST /api/tasks validates estimated_time but ignores it, and the
    # field's unit is MINUTES (the web UI sends hours*60+minutes). So we convert
    # seconds -> minutes and apply the estimate with a follow-up PATCH.
    local extra=""
    if [ -n "$estimate" ]; then
        local est_minutes=$(( (estimate + 59) / 60 ))
        api PATCH "/tasks/$task_id" "{\"estimated_time\": $est_minutes}"
        check_status
        extra=" (estimate: ${est_minutes}m)"
    fi
    if [ -n "$skills_attached" ]; then
        extra="$extra (skills: $skills_attached)"
    elif printf '%s' "$description" | grep -q '#'; then
        extra="$extra (warning: no matching skills found — #tags only attach to skills that already exist on deepworktimer.com)"
    fi
    echo "Created task $task_id: $description$extra"
}

cmd_done() {
    require_token
    local task_id="${1:-}"
    [ -n "$task_id" ] || die "usage: dwt done <task_id>"
    api PATCH "/tasks/$task_id" '{"completed": true}'
    check_status
    py '
import json, os
t = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("task") or {}
print("Completed task {}: {}".format(t.get("id"), t.get("description")))
'
}


# ---- server-side sessions (deepworktimer >= 2026-06-11) --------------------
# One active session per ACCOUNT, visible from every machine. Falls back to
# the local session file when the server predates the endpoints (404).

# Stable per-machine identity used as the session `source` and for all
# device scoping. `hostname -s` is NOT stable on macOS — it follows DHCP /
# reverse-DNS and flips to a MAC address when the network has no name, so a
# machine would eventually stop recognising its own sessions. Prefer the
# macOS LocalHostName (set in Sharing, stable across networks), then fall
# back to hostname on other platforms. The hooks replicate this exactly.
machine_label() {
    scutil --get LocalHostName 2>/dev/null \
        || hostname -s 2>/dev/null \
        || hostname 2>/dev/null \
        || echo "dwt"
}

PY_SESSION_SUMMARY='
import json, os, sys
d = json.loads(os.environ["API_BODY"])
s = d.get("session")
if not s:
    print("none")
    sys.exit(0)
rem = int(s.get("remaining_seconds") or 0)
segs = s.get("segments") or []
cur = next((x for x in reversed(segs) if x.get("seconds") is None), {})
desc = (cur.get("task_description") or "").replace("|", "/")
# the device accruing the OPEN segment owns the session right now; legacy
# segments have no src and fall back to whoever started the session
seg_src = cur.get("src") or s.get("source") or "?"
parts = ["id=%s" % s["id"], "remaining=%s" % rem, "source=%s" % (s.get("source") or "?"),
         "seg_src=%s" % seg_src,
         "task=%s" % (cur.get("task_id") if cur.get("task_id") is not None else "-"),
         "desc=%s" % desc, "overdue=%s" % ("yes" if s.get("overdue") else "no"),
         "segments=%s" % len(segs)]
print("|".join(str(p) for p in parts))
'

server_session_get() {  # sets SRV_*; returns 1 if no endpoint, 2 if none active
    api GET "/session"
    [ "$API_STATUS" = "404" ] && return 1
    check_status
    local line
    line=$(py "$PY_SESSION_SUMMARY")
    [ "$line" = "none" ] && return 2
    SRV_ID="${line%%|*}";       SRV_ID="${SRV_ID#id=}"
    SRV_REMAINING=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^remaining=//p")
    SRV_SOURCE=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^source=//p")
    SRV_SEG_SRC=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^seg_src=//p")
    [ -n "$SRV_SEG_SRC" ] || SRV_SEG_SRC="$SRV_SOURCE"
    SRV_TASK=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^task=//p")
    SRV_DESC=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^desc=//p")
    SRV_OVERDUE=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^overdue=//p")
    SRV_SEGMENTS=$(printf "%s" "$line" | tr "|" "\n" | sed -n "s/^segments=//p")
    return 0
}

cmd_start() {
    require_token
    local task_id="" minutes=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --minutes) minutes="${2:?--minutes needs a value}"; shift 2 ;;
            *) task_id="$1"; shift ;;
        esac
    done
    [ -n "$task_id" ] || die "usage: dwt start <task_id> [--minutes <n>]"
    if [ -n "$minutes" ]; then
        { [ "$minutes" -ge 1 ] && [ "$minutes" -le 240 ]; } 2>/dev/null \
            || die "--minutes must be 1..240 (server accepts 60..14400 seconds)"
    fi

    local body
    body=$(py '
import json, sys
payload = {"task_id": int(sys.argv[1]), "source": sys.argv[2]}
if sys.argv[3]:
    payload["duration_seconds"] = max(60, int(sys.argv[3]) * 60)
print(json.dumps(payload))
' "$task_id" "$(machine_label)" "$minutes")
    api POST "/session/start" "$body"
    if [ "$API_STATUS" != "404" ]; then
        check_status
        local took
        took=$(py '
import json, os
print(json.loads(os.environ["API_BODY"]).get("took_over") or "")
')
        [ -n "$took" ] && echo "note: took over the session that was running on: $took" >&2
        rm -f "$SESSION_FILE"
        refresh_statusline_cache
        echo "Session started on task $task_id (server-side — visible from every machine; run dwt log or dwt switch <id> next)"
        return 0
    fi

    # server predates sessions — local fallback
    if read_session; then
        echo "note: replacing existing session (task $SESSION_TASK_ID started $SESSION_STARTED_AT)" >&2
    fi
    local started
    started=$(now_utc)
    printf 'TASK_ID=%s\nSTARTED_AT=%s\n' "$task_id" "$started" > "$SESSION_FILE"
    echo "Session started on task $task_id at $started (local state only — run 'dwt log' to record it)"
}

cmd_switch() {
    require_token
    local task_id="${1:-}"
    [ -n "$task_id" ] || die "usage: dwt switch <task_id>"
    local body
    body=$(py '
import json, sys
print(json.dumps({"task_id": int(sys.argv[1]), "source": sys.argv[2]}))
' "$task_id" "$(machine_label)")
    api POST "/session/switch" "$body"
    [ "$API_STATUS" = "404" ] && die "no active server session (or the server predates sessions). Run: dwt start <task_id>"
    check_status
    refresh_statusline_cache
    echo "Switched the active session to task $task_id — time keeps accruing in the same pomodoro."
}

cmd_abandon() {
    require_token
    local force=0
    [ "${1:-}" = "--force" ] && force=1
    # ownership follows the OPEN SEGMENT's device (who is accruing right
    # now), not the session starter — a laptop that latched in via
    # `dwt switch` owns the paperwork from that moment.
    if [ "$force" != 1 ] && server_session_get && [ "$SRV_SEG_SRC" != "$(machine_label)" ]; then
        die "the open segment is accruing on '$SRV_SEG_SRC', not this machine — abandoning from here would silently kill the user's timer there. Re-run with --force only if the user explicitly asks."
    fi
    api DELETE "/session"
    [ "$API_STATUS" = "404" ] && { rm -f "$SESSION_FILE"; echo "No server session; cleared any local one."; return 0; }
    check_status
    rm -f "$SESSION_FILE"
    refresh_statusline_cache
    echo "Session abandoned — nothing logged."
}

cmd_autonomous() {
    # Per-machine flag: does THIS device seize a session owned by another
    # device, or defer to it (default)? Persisted in the config file so the
    # hooks (which source config) pick it up. Config is per-machine (not in
    # the skill repo), so each machine sets its own stance.
    local action="${1:-status}"
    case "$action" in
        on|off)
            local val=0; [ "$action" = "on" ] && val=1
            CONFIG_FILE="$CONFIG_FILE" VAL="$val" python3 - <<'PYEOF'
import os
path = os.environ["CONFIG_FILE"]
val = os.environ["VAL"]
lines = []
if os.path.exists(path):
    with open(path) as f:
        lines = [l for l in f.read().splitlines() if not l.startswith("DWT_AUTONOMOUS=")]
lines.append("DWT_AUTONOMOUS=" + val)
with open(path + ".tmp", "w") as f:
    f.write("\n".join(lines) + "\n")
os.replace(path + ".tmp", path)
PYEOF
            rm -f "$CONFIG_DIR/statusline-cache"
            if [ "$val" = 1 ]; then
                echo "Autonomous mode ON for '$(machine_label)': this machine silently takes over a session owned by another device (mapped windows seize on prompt; foreign sessions are hidden from its statusline)."
            else
                echo "Autonomous mode OFF for '$(machine_label)': foreign-owned sessions are protected (default) — surfaced, never auto-taken."
            fi
            ;;
        status)
            if [ "$DWT_AUTONOMOUS" = "1" ]; then
                echo "autonomous: ON — '$(machine_label)' seizes foreign-owned sessions"
            else
                echo "autonomous: OFF — '$(machine_label)' defers to foreign-owned sessions"
            fi
            ;;
        *) die "usage: dwt autonomous [on|off|status]" ;;
    esac
}

cmd_hooks_install() {
    # Add a UserPromptSubmit hook that injects the live session state into
    # Claude's context every prompt (idempotent; settings.json only).
    python3 - <<'PYEOF'
import json, os, sys

settings_path = os.path.expanduser('~/.claude/settings.json')
cmd = os.path.expanduser('~/.claude/skills/deepwork-timer/bin/dwt-context')

settings = {}
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)

hooks = settings.setdefault('hooks', {})
entries = hooks.setdefault('UserPromptSubmit', [])
for entry in entries:
    for h in entry.get('hooks', []):
        if 'dwt-context' in h.get('command', ''):
            print('dwt context hook already installed — nothing to do')
            sys.exit(0)

entries.append({'matcher': '*', 'hooks': [{'type': 'command', 'command': cmd, 'timeout': 5}]})

with open(settings_path + '.tmp', 'w') as f:
    json.dump(settings, f, indent=2)
os.replace(settings_path + '.tmp', settings_path)
print('dwt context hook installed: session state now appears in Claude\'s context every prompt')
PYEOF
}

cmd_statusline_install() {
    # Wrap this machine's existing Claude Code statusline with the dwt
    # segment, touching only ~/.claude/settings.json (idempotent).
    python3 - <<'PYEOF'
import json, os, sys

settings_path = os.path.expanduser('~/.claude/settings.json')
wrap = os.path.expanduser('~/.claude/skills/deepwork-timer/bin/dwt-statusline-wrap')

settings = {}
if os.path.exists(settings_path):
    with open(settings_path) as f:
        settings = json.load(f)

current = (settings.get('statusLine') or {}).get('command', '')
if wrap in current or 'dwt-statusline-wrap' in current:
    print('statusline already wrapped — nothing to do')
    sys.exit(0)

new_cmd = wrap + (' ' + current if current else '')
settings['statusLine'] = {'type': 'command', 'command': new_cmd}

with open(settings_path + '.tmp', 'w') as f:
    json.dump(settings, f, indent=2)
os.replace(settings_path + '.tmp', settings_path)
print('statusline wrapped: ' + new_cmd)
print('(your original statusline still renders; the dwt segment is appended)')
PYEOF
}

cmd_log() {
    require_token
    local task="" minutes="" force=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --task)    task="${2:?--task needs a value}"; shift 2 ;;
            --minutes) minutes="${2:?--minutes needs a value}"; shift 2 ;;
            --force)   force=1; shift ;;
            *) die "unexpected argument: $1" ;;
        esac
    done

    # server session takes precedence when no explicit overrides are given
    if [ -z "$task" ] && [ -z "$minutes" ]; then
        if server_session_get; then
            # The session is shared account-wide; ownership follows the
            # OPEN SEGMENT. If another device is accruing right now (phone
            # at the gym, the other laptop), the human's attention is THERE
            # — completing it from here would cut their timer off. A device
            # that latched in via `dwt switch` owns the open segment and may
            # log freely, even if the session was started elsewhere.
            if [ "$SRV_SEG_SRC" != "$(machine_label)" ] && [ "$force" != 1 ]; then
                die "the open segment is accruing on '$SRV_SEG_SRC', not this machine — the user may be working there (phone/gym/other laptop). Log from there, or re-run with --force only if the user explicitly asks."
            fi
            api POST "/session/complete"
            check_status
            refresh_statusline_cache
            py '
import json, os
d = json.loads(os.environ["API_BODY"])
p = d.get("pomodoro") or {}
secs = int(p.get("time") or 0)
tasks = p.get("tasks") or []
split = ", ".join("task {}: {}m".format(t["id"], (t.get("pivot") or {}).get("effort_time", 0) // 60) for t in tasks)
print("Logged {}m total{}.".format(secs // 60, " ({})".format(split) if split else ""))
'
            return 0
        fi
    fi

    local have_session=0
    read_session && have_session=1

    if [ -z "$task" ]; then
        [ "$have_session" = 1 ] || die "no active session and no --task given. Run: dwt start <task_id>  or  dwt log --task <id> --minutes <n>"
        task="$SESSION_TASK_ID"
    fi

    local seconds
    if [ -n "$minutes" ]; then
        seconds=$(( minutes * 60 ))
    else
        [ "$have_session" = 1 ] || die "no active session — pass --minutes <n> to log a fixed amount"
        seconds=$(elapsed_seconds "$SESSION_STARTED_AT")
    fi
    [ "$seconds" -gt 0 ] || die "nothing to log (elapsed time is 0s)"

    local body
    body=$(py '
import json, sys
secs, task = int(sys.argv[1]), int(sys.argv[2])
print(json.dumps({"time": secs, "tasks": [{"id": task, "effort_time": secs}]}))
' "$seconds" "$task")
    api POST "/pomodoro" "$body"
    check_status

    # close the local session if it was the one we just logged
    if [ "$have_session" = 1 ] && [ "$task" = "$SESSION_TASK_ID" ]; then
        rm -f "$SESSION_FILE"
    fi
    refresh_statusline_cache
    echo "Logged $(pretty_duration "$seconds") on task $task."
}

# map a working directory to a task id; the dwt-context hook uses this to
# steer the active session's segment toward whichever Claude Code window
# the user is actually prompting in (see SKILL.md "Multiple sessions").
cmd_map() {
    local taskmap="$CONFIG_DIR/taskmap"
    if [ $# -eq 0 ]; then
        if [ -s "$taskmap" ]; then
            printf 'TASK    PATH\n'
            while IFS=$'\t' read -r tid tpath; do
                printf '%-7s %s\n' "$tid" "$tpath"
            done < "$taskmap"
        else
            echo "(no mappings — add one with: dwt map <task_id> [path])"
        fi
        return 0
    fi

    local remove=0 task="" target=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --remove) remove=1; shift ;;
            *) if [ -z "$task" ] && [ "$remove" = 0 ]; then task="$1"; else target="$1"; fi; shift ;;
        esac
    done
    target="${target:-$PWD}"
    target=$(cd "$target" 2>/dev/null && pwd -P) || die "no such directory: $target"

    local tmp="$taskmap.tmp"
    { [ -f "$taskmap" ] && grep -v "	$target\$" "$taskmap"; } > "$tmp" || true
    if [ "$remove" = 1 ]; then
        mv "$tmp" "$taskmap"
        echo "Unmapped $target"
        return 0
    fi
    case "$task" in (*[!0-9]*|'') die "usage: dwt map <task_id> [path]  (or: dwt map --remove [path])" ;; esac
    printf '%s\t%s\n' "$task" "$target" >> "$tmp"
    mv "$tmp" "$taskmap"
    echo "Mapped $target -> task $task (longest-prefix match wins across mappings)"
}

# latch a task onto the Claude Code session the user most recently
# prompted (per the dwt-context breadcrumb). A latch outranks the cwd map
# in the arbiter — it is how two windows in the SAME directory track
# different tasks.
cmd_latch() {
    local latches="$CONFIG_DIR/latches" last="$CONFIG_DIR/last-prompt"
    if [ $# -eq 0 ]; then
        if [ -s "$latches" ]; then
            printf 'SESSION                                TASK\n'
            while IFS=$'\t' read -r sid tid _; do
                printf '%-38s %s\n' "$sid" "$tid"
            done < "$latches"
        else
            echo "(no latches — run: dwt latch <task_id> right after the user prompts the window to bind)"
        fi
        return 0
    fi

    [ -s "$last" ] || die "no prompt breadcrumb yet — the dwt-context hook must fire once (user prompts this window) before latching"
    local sid
    sid=$(cut -f1 "$last")
    [ -n "$sid" ] || die "breadcrumb is empty — prompt this window once and retry"

    local tmp="$latches.tmp"
    { [ -f "$latches" ] && grep -v "^$sid	" "$latches"; } > "$tmp" || true
    if [ "$1" = "--clear" ]; then
        mv "$tmp" "$latches"
        echo "Unlatched session $sid"
        return 0
    fi
    case "$1" in (*[!0-9]*|'') die "usage: dwt latch <task_id>   (or: dwt latch --clear; no args lists latches)" ;; esac
    printf '%s\t%s\t%s\n' "$sid" "$1" "$(date +%s)" >> "$tmp"
    mv "$tmp" "$latches"
    echo "Latched session $sid -> task $1 (outranks the cwd map for this window)"
}

# hide a task from the default lists until a wake time ("show up after
# X"): dwt snooze <id> 3d|5h|45m|<ISO date>, or --clear to wake it now.
cmd_snooze() {
    require_token
    local task_id="${1:-}" when="${2:-}"
    [ -n "$task_id" ] || die "usage: dwt snooze <task_id> <3d|5h|45m|YYYY-MM-DD[THH:MM]>  (or: dwt snooze <task_id> --clear)"
    local body
    if [ "$when" = "--clear" ]; then
        body='{"snoozed_until": null}'
    else
        [ -n "$when" ] || die "usage: dwt snooze <task_id> <3d|5h|45m|YYYY-MM-DD[THH:MM]>  (or --clear)"
        body=$(py '
import datetime, json, re, sys
w = sys.argv[1]
m = re.fullmatch(r"(\d+)([mhd])", w)
if m:
    n, unit = int(m.group(1)), m.group(2)
    delta = {"m": "minutes", "h": "hours", "d": "days"}[unit]
    ts = datetime.datetime.now(datetime.timezone.utc) + datetime.timedelta(**{delta: n})
else:
    try:
        ts = datetime.datetime.fromisoformat(w)
    except ValueError:
        sys.exit("dwt: cannot parse \"{}\" — use 3d / 5h / 45m or an ISO date".format(w))
    if ts.tzinfo is None:
        ts = ts.astimezone()
print(json.dumps({"snoozed_until": ts.isoformat()}))
' "$when") || exit 1
    fi
    api PATCH "/tasks/$task_id" "$body"
    check_status
    if [ "$when" = "--clear" ]; then
        echo "Task $task_id is awake — back in the default lists."
    else
        echo "Task $task_id snoozed — hidden until $(py 'import json,sys; print(json.loads(sys.argv[1])["snoozed_until"])' "$body"). See it with: dwt tasks --later"
    fi
}

# recurrence: completing the task then re-snoozes it until the next wake.
cmd_repeat() {
    require_token
    local task_id="${1:-}" rule="${2:-}"
    [ -n "$task_id" ] && [ -n "$rule" ] || die "usage: dwt repeat <task_id> <every:7d|every:12h|weekly:mon,thu>  (or: dwt repeat <task_id> --clear)"
    local body
    if [ "$rule" = "--clear" ]; then
        body='{"recurrence": null}'
    else
        body=$(py 'import json,sys; print(json.dumps({"recurrence": sys.argv[1]}))' "$rule")
    fi
    api PATCH "/tasks/$task_id" "$body"
    check_status
    if [ "$rule" = "--clear" ]; then
        echo "Task $task_id no longer repeats."
    else
        echo "Task $task_id repeats ($rule): completing it records the cycle and re-snoozes it until the next wake — a Web Push fires when it is due."
    fi
}

cmd_status() {
    require_token
    local srv_rc
    server_session_get; srv_rc=$?
    if [ "$srv_rc" = 0 ]; then
        local where=""
        [ "$SRV_SEG_SRC" != "$(machine_label)" ] && where=" on $SRV_SEG_SRC"
        if [ "$SRV_OVERDUE" = "yes" ]; then
            label="task $SRV_TASK"; [ -n "$SRV_DESC" ] && label="$SRV_DESC (task $SRV_TASK)"
            echo "Active session$where: $label — finished (run 'dwt log' to record it; $SRV_SEGMENTS segment(s))"
        else
            label="task $SRV_TASK"; [ -n "$SRV_DESC" ] && label="$SRV_DESC (task $SRV_TASK)"
            echo "Active session$where: $label — $(pretty_duration "$SRV_REMAINING") remaining ($SRV_SEGMENTS segment(s))"
        fi
    elif [ "$srv_rc" = 2 ]; then
        # the server is authoritative: no active session anywhere
        rm -f "$SESSION_FILE"
        echo "No active session. Start one with: dwt start <task_id>"
    elif read_session; then
        local elapsed
        elapsed=$(elapsed_seconds "$SESSION_STARTED_AT")
        echo "Active session: task $SESSION_TASK_ID — $(pretty_duration "$elapsed") elapsed (started $SESSION_STARTED_AT)"
    else
        echo "No active session. Start one with: dwt start <task_id>"
    fi
    fetch_general_stats
    py '
import json, os
stats = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("stats") or {}
today = (stats.get("total_time") or {}).get("today") or {}
print("Today total focus time: {}".format(today.get("human_friendly_time") or "0 minutes"))
'
}

cmd_stats() {
    require_token
    fetch_general_stats
    py '
import json, os
stats = (json.loads(os.environ["API_BODY"]).get("data") or {}).get("stats") or {}
tt = stats.get("total_time") or {}
def row(label, key):
    print("{:<15}{}".format(label, (tt.get(key) or {}).get("human_friendly_time") or "0 minutes"))
print("Focus time")
print("----------")
row("Today:", "today")
row("Last 7 days:", "last_7_days")
row("Last 30 days:", "last_30_days")
row("Last 365 days:", "last_365_days")
row("All time:", "all_time")
def hum(seconds):
    s = int(float(seconds or 0)); h, m = s // 3600, (s % 3600) // 60
    return "{}h {}m".format(h, m) if h else "{}m".format(m)
best = stats.get("best") or {}
if best.get("date"):
    # human_friendly_date already embeds the duration, e.g. "0h26m on 9 Jun, 2026"
    label = best.get("human_friendly_date") or "{} on {}".format(hum(best.get("total_time")), best["date"])
    print("{:<15}{}".format("Best day:", label))
avg = stats.get("average")
if avg:
    print("{:<15}{} (over last 30 days)".format("Daily average:", hum(avg)))
'
}

# ------------------------------------------------------------------ main ----
cmd="${1:-}"
[ $# -gt 0 ] && shift

# Activity heartbeat: a session-affecting dwt command means the agent is
# working right now. The idle-aware hook reads this so a long autonomous
# turn (no new prompts, but real work) still counts as continuous activity.
case "$cmd" in
    start|switch|log|add|done|snooze|repeat) date +%s > "$CONFIG_DIR/last-activity" 2>/dev/null || true ;;
esac

case "$cmd" in
    login)    cmd_login "$@" ;;
    token)    cmd_token "$@" ;;
    whoami)   cmd_whoami "$@" ;;
    projects) cmd_projects "$@" ;;
    tasks)    cmd_tasks "$@" ;;
    add)      cmd_add "$@" ;;
    done)     cmd_done "$@" ;;
    start)    cmd_start "$@" ;;
    switch)   cmd_switch "$@" ;;
    abandon)  cmd_abandon "$@" ;;
    log)      cmd_log "$@" ;;
    statusline-install) cmd_statusline_install "$@" ;;
    hooks-install) cmd_hooks_install "$@" ;;
    autonomous) cmd_autonomous "$@" ;;
    map)      cmd_map "$@" ;;
    snooze)   cmd_snooze "$@" ;;
    repeat)   cmd_repeat "$@" ;;
    latch)    cmd_latch "$@" ;;
    status)   cmd_status "$@" ;;
    stats)    cmd_stats "$@" ;;
    ""|-h|--help|help) usage ;;
    *) usage >&2; die "unknown command: $cmd" ;;
esac
